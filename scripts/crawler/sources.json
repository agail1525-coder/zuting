{
  "$schema": "./sources.schema.json",
  "version": "1.0.0",
  "updatedAt": "2026-04-14",
  "note": "爬虫++ 5×6 矩阵源登记。CW-21 禁硬编码,改源先改此文件再 seed-sources.mjs upsert。CW-39 新源 PRD 先行。",
  "matrix": {
    "domains": ["HOLY_SITE", "MERCHANT", "PRICE", "GUIDE", "NEWS"],
    "channels": ["OFFICIAL", "WIKI", "OTA", "MAP", "UGC", "MEDIA"]
  },
  "sources": [
    {
      "key": "wiki-holy-site-en",
      "name": "Wikipedia EN — Holy Sites",
      "baseUrl": "https://en.wikipedia.org/api/rest_v1/page/summary/",
      "type": "GUIDE",
      "targetDomain": "HOLY_SITE",
      "channel": "WIKI",
      "priority": 5,
      "schedule": "0 */6 * * *",
      "parser": "wiki-rest",
      "strategy": "API",
      "rateLimitMs": 1500,
      "enabled": true,
      "selector": { "list": "$", "title": "title", "description": "extract", "images": "thumbnail.source", "url": "content_urls.desktop.page" },
      "notes": "公开 API, 用圣地名作 slug 拼接"
    },
    {
      "key": "wiki-holy-site-zh",
      "name": "Wikipedia 中文 — 圣地",
      "baseUrl": "https://zh.wikipedia.org/api/rest_v1/page/summary/",
      "type": "GUIDE",
      "targetDomain": "HOLY_SITE",
      "channel": "WIKI",
      "priority": 5,
      "schedule": "15 */6 * * *",
      "parser": "wiki-rest",
      "strategy": "API",
      "rateLimitMs": 1500,
      "enabled": true,
      "selector": { "list": "$", "title": "title", "description": "extract", "images": "thumbnail.source", "url": "content_urls.desktop.page" },
      "notes": "中文原文优先,CW-34 与 EN 分离"
    },
    {
      "key": "wikidata-p18",
      "name": "Wikidata SPARQL — 圣地图片 P18",
      "baseUrl": "https://query.wikidata.org/sparql",
      "type": "GUIDE",
      "targetDomain": "HOLY_SITE",
      "channel": "WIKI",
      "priority": 5,
      "schedule": "30 4 * * *",
      "parser": "wikidata-sparql",
      "strategy": "API",
      "rateLimitMs": 3000,
      "enabled": true,
      "selector": { "list": "results.bindings", "images": "image.value", "title": "itemLabel.value", "url": "item.value" },
      "notes": "沿用 Phase 3 成果,新圣地补图"
    },
    {
      "key": "wikipedia-commons-images",
      "name": "Wikipedia Commons — 圣地图片",
      "baseUrl": "https://commons.wikimedia.org/w/api.php",
      "type": "GUIDE",
      "targetDomain": "HOLY_SITE",
      "channel": "WIKI",
      "priority": 4,
      "schedule": "0 5 * * *",
      "parser": "commons-api",
      "strategy": "API",
      "rateLimitMs": 2000,
      "enabled": true,
      "selector": { "list": "query.pages", "images": "imageinfo[0].url", "title": "title", "url": "canonicalurl" }
    },
    {
      "key": "baidu-baike-holy-site",
      "name": "百度百科 — 圣地",
      "baseUrl": "https://baike.baidu.com/item/",
      "type": "GUIDE",
      "targetDomain": "HOLY_SITE",
      "channel": "WIKI",
      "priority": 3,
      "schedule": "0 6 * * *",
      "parser": "baidu-baike",
      "strategy": "HTTP",
      "rateLimitMs": 3000,
      "enabled": false,
      "selector": { "list": ".lemmaSummary", "title": "h1", "description": ".lemma-summary", "images": ".summary-pic img" },
      "notes": "CW-33 图片需本地化, T2 待启用"
    },
    {
      "key": "gaode-poi",
      "name": "高德地图 POI",
      "baseUrl": "https://restapi.amap.com/v3/place/text",
      "type": "OFFICIAL",
      "targetDomain": "HOLY_SITE",
      "channel": "MAP",
      "priority": 4,
      "schedule": "0 7 * * *",
      "parser": "gaode-poi",
      "strategy": "API",
      "rateLimitMs": 500,
      "enabled": false,
      "selector": { "list": "pois", "title": "name", "coords": "location", "images": "photos[0].url" },
      "notes": "需 AMAP_KEY 环境变量, 国内景区 GPS 校验"
    },
    {
      "key": "google-places",
      "name": "Google Places API",
      "baseUrl": "https://maps.googleapis.com/maps/api/place/textsearch/json",
      "type": "OFFICIAL",
      "targetDomain": "HOLY_SITE",
      "channel": "MAP",
      "priority": 3,
      "schedule": "0 8 * * *",
      "parser": "google-places",
      "strategy": "API",
      "rateLimitMs": 500,
      "enabled": false,
      "proxyNeeded": true,
      "selector": { "list": "results", "title": "name", "coords": "geometry.location", "rating": "rating" },
      "notes": "GFW 外, CW-32 代理池. 需 GOOGLE_PLACES_KEY"
    },
    {
      "key": "booking-public",
      "name": "Booking.com 公开元数据",
      "baseUrl": "https://www.booking.com",
      "type": "HOTEL",
      "targetDomain": "MERCHANT",
      "channel": "OTA",
      "priority": 3,
      "schedule": "0 2 * * *",
      "parser": "booking-html",
      "strategy": "HTTP",
      "rateLimitMs": 5000,
      "enabled": false,
      "proxyNeeded": true,
      "selector": { "list": "[data-testid='property-card']", "title": "[data-testid='title']", "price": "[data-testid='price-and-discounted-price']", "rating": "[data-testid='review-score']" },
      "notes": "CW-01 robots.txt, CW-31 仅聚合禁转售, T2 T3 待合规审"
    },
    {
      "key": "ctrip-public",
      "name": "携程公开数据",
      "baseUrl": "https://hotels.ctrip.com",
      "type": "HOTEL",
      "targetDomain": "MERCHANT",
      "channel": "OTA",
      "priority": 2,
      "schedule": "0 3 * * *",
      "parser": "ctrip-html",
      "strategy": "HTTP",
      "rateLimitMs": 5000,
      "enabled": false,
      "selector": { "list": ".hotel-item", "title": ".hotel-name", "price": ".price", "rating": ".score" }
    },
    {
      "key": "dianping-public",
      "name": "大众点评餐饮 (公开页)",
