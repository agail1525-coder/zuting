      "strategy": "HTTP",
      "rateLimitMs": 4000,
      "enabled": false,
      "proxyNeeded": true,
      "selector": { "list": "[data-testid='flight-card']", "price": "[data-testid='price']", "title": "[data-testid='airline-name']" }
    },
    {
      "key": "trip-com-public",
      "name": "Trip.com 公开价",
