# ==============================================
# Zuting API — Environment Variables
# ==============================================
# Copy this file to .env and fill in actual values.
# Required vars are marked with [REQUIRED].

# ---- Database ----
# [REQUIRED] PostgreSQL connection string (PostGIS image used for geo queries)
DATABASE_URL="postgresql://zuting:zuting123@localhost:5435/zuting?schema=public"

# ---- Redis ----
# [REQUIRED] Redis connection URL (used for caching & rate limiting)
REDIS_URL="redis://localhost:6380"

# ---- JWT Authentication ----
# [REQUIRED] Secret key for signing JWT tokens — MUST change in production
JWT_SECRET="change-me-in-production"
# Token expiration time
JWT_EXPIRES_IN="7d"
# Refresh token expiration time
JWT_REFRESH_EXPIRES_IN="30d"

# ---- Server ----
# Port the NestJS API listens on
API_PORT=3002
# Environment: development | production | test
NODE_ENV="development"

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3003"

# ---- AI (Xiaohong Chat) ----
# OpenAI-compatible API for Xiaohong LLM (vLLM / Ollama / OpenAI etc.)
# Leave empty to use rule-based fallback engine
LLM_BASE_URL="http://120.24.31.151:18001/v1"
LLM_API_KEY="zuoyelang2026"
LLM_MODEL="/root/autodl-tmp/models/Qwen/Qwen3___5-122B-A10B-GPTQ-Int4"

# ---- File Storage (choose one) ----
# Aliyun OSS
# OSS_ACCESS_KEY_ID=""
# OSS_ACCESS_KEY_SECRET=""
# OSS_BUCKET=""
# OSS_REGION=""
# OSS_ENDPOINT=""

# AWS S3 (alternative)
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET=""
# S3_REGION=""

# ---- Payment (Phase 3) ----
# WeChat Pay
# WECHAT_PAY_APP_ID=""
# WECHAT_PAY_MCH_ID=""
# WECHAT_PAY_API_KEY=""
# WECHAT_PAY_NOTIFY_URL=""

# Alipay
# ALIPAY_APP_ID=""
# ALIPAY_PRIVATE_KEY=""
# ALIPAY_PUBLIC_KEY=""
# ALIPAY_NOTIFY_URL=""

# Stripe (international)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ---- Email (SMTP) ----
# SMTP configuration for sending verification codes, order confirmations, etc.
# Leave empty to use console.log fallback (dev mode)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zuting.com

# ---- SMS (Aliyun) ----
# Alibaba Cloud SMS configuration for sending verification codes
# Leave empty to use console.log fallback (dev mode)
SMS_PROVIDER=aliyun
ALIYUN_ACCESS_KEY=
ALIYUN_SECRET=
ALIYUN_SMS_SIGN=祖庭之旅
ALIYUN_SMS_TEMPLATE=SMS_123456

# ---- Sentry Error Monitoring ----
# Sentry DSN for the API service — leave empty to disable
SENTRY_DSN_API=""

# ---- WeChat Login (Phase 3) ----
# WECHAT_APP_ID=""
# WECHAT_APP_SECRET=""

# ---- Google OAuth (Phase 3) ----
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
