// ========== 商家入驻 ==========

model Merchant {
  id            String         @id @default(cuid())
  userId        String         @unique
  type          String         // TEMPLE / GUIDE / ACCOMMODATION / TRANSPORT
  name          String
  description   String?        @db.Text
  logo          String?
  license       String?        // 营业执照/资质证书URL
  status        MerchantStatus @default(PENDING)
  contactPhone  String?
  contactEmail  String?
  address       String?
  province      String?
  city          String?
  rating        Float          @default(0)
  totalOrders   Int            @default(0)
  totalRevenue  Int            @default(0) // cents
  rejectedReason String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  services MerchantService[]

  @@index([type, status])
  @@index([status])
}

model MerchantService {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  name        String
  description String?  @db.Text
  coverImage  String?
  price       Int      // cents
  duration    Int?     // minutes
  maxPersons  Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([merchantId, isActive])
}

enum MerchantStatus {
  PENDING   // 待审核
  APPROVED  // 审核通过
  ACTIVE    // 正常运营
  SUSPENDED // 已暂停
  REJECTED  // 已拒绝
  CLOSED    // 已关闭
}

// ========== 实时消息 ==========

model ChatRoom {
  id        String   @id @default(cuid())
  type      String   // PRIVATE / MERCHANT_INQUIRY / GUIDE_CHAT
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([type])
}

model ChatParticipant {
  id         String    @id @default(cuid())
  roomId     String
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  type      String   @default("TEXT") // TEXT / IMAGE / SYSTEM
  content   String   @db.Text
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([senderId])
}

// ========== 多媒体导览 ==========

model MediaContent {
  id           String   @id @default(cuid())
  entityType   String   // HOLY_SITE / TEMPLE
  entityId     String
  mediaType    String   // VIDEO / PANORAMA / AUDIO
  title        String
  description  String?  @db.Text
  url          String   // 媒体文件URL
  thumbnailUrl String?  // 缩略图
  duration     Int?     // 时长(秒)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId, isActive])
  @@index([mediaType])
}

// ========== M32 团队文化打造 (Team Culture) ==========

model Team {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  orgType      TeamOrgType
  industry     String?
  size         Int               @default(0)
  description  String?           @db.Text
  logoUrl      String?
  coverUrl     String?
  city         String?
  country      String?
  ownerId      String
  owner        User              @relation("TeamOwner", fields: [ownerId], references: [id])
  members      TeamMember[]
  inquiries    TeamInquiry[]
  certificates TeamCertificate[]
  invites      TeamInvite[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([ownerId])
  @@index([orgType])
}

enum TeamOrgType {
  ENTERPRISE
  EXECUTIVE
  FAMILY_OFFICE
  SCHOOL
  RELIGIOUS
  NGO
  FAMILY
  GOVERNMENT
  OTHER
}

model TeamMember {
  id       String         @id @default(cuid())
  teamId   String
  team     Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     TeamMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

enum TeamMemberRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  token     String   @unique
  role      TeamMemberRole @default(MEMBER)
  createdBy String
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime @default(now())

  @@index([teamId])
}

enum CultureCategory {
  TEAM
  PERSONAL
  FAMILY
}

model TeamCultureTheme {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  subtitle    String?
  description String          @db.Text
  color       String
  icon        String?
  coverUrl    String?
  keywords    String[]
  holySites   String[]        // holySite slug array
  routes      String[]        // route slug array
  rituals     Json?           // [{name,durationMin,description}]
  richContent Json?           // 深度内容: dimension/painPoint/philosophy/dailyItinerary/mentors/deliverables/audience/whyZuting
  priceFrom   Int?            // 起价(分)
  durationDays Int?
  category    CultureCategory @default(TEAM)  // TEAM=团队文化 | PERSONAL=个人成长 | FAMILY=家庭和谐
  sortOrder   Int             @default(0)
  isPublished Boolean         @default(true)
  inquiries   TeamInquiry[]
  cases       TeamCase[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([isPublished, sortOrder])
  @@index([category, isPublished])
}

model TeamInquiry {
  id          String            @id @default(cuid())
  teamId      String?
  team        Team?             @relation(fields: [teamId], references: [id])
  themeId     String?
  theme       TeamCultureTheme? @relation(fields: [themeId], references: [id])
  contactName String
  contactRole String?
  phone       String
  email       String?
  orgName     String
  headcount   Int
  budget      Int?              // 分
  preferredAt DateTime?
  message     String?           @db.Text
  source      String?           // utm
  category    CultureCategory   @default(TEAM)
  status      TeamInquiryStatus @default(NEW)
  assignedTo  String?
  logs        TeamInquiryLog[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([category, status])
  @@index([assignedTo])
  @@index([createdAt])
}

enum TeamInquiryStatus {
  NEW
  CONTACTED
  QUOTED
  SIGNED
  DELIVERED
  CLOSED
  LOST
}

model TeamInquiryLog {
  id         String             @id @default(cuid())
  inquiryId  String
  inquiry    TeamInquiry        @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  fromStatus TeamInquiryStatus?
  toStatus   TeamInquiryStatus
  operatorId String
  note       String?            @db.Text
  createdAt  DateTime           @default(now())

  @@index([inquiryId])
}

model TeamCase {
  id            String            @id @default(cuid())
  slug          String            @unique
  teamName      String
  orgType       TeamOrgType
  industry      String?
  themeId       String?
  theme         TeamCultureTheme? @relation(fields: [themeId], references: [id])
  headcount     Int
  story         String            @db.Text
  highlights    String[]
  photos        String[]
  videoUrl      String?
  testimonial   String?           @db.Text
  consentSigned Boolean           @default(false)
  category      CultureCategory   @default(TEAM)
  isPublished   Boolean           @default(false)
  publishedAt   DateTime?
  viewCount     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([isPublished, publishedAt])
  @@index([category, isPublished])
}

model TeamCertificate {
  id            String    @id @default(cuid())
  teamId        String
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tripId        String?
  themeId       String?
  title         String
  serialNo      String    @unique
  pdfUrl        String?
  imageUrl      String?
  issuedAt      DateTime  @default(now())
  revokedAt     DateTime?
  revokedReason String?

  @@index([teamId])
}

// ========== 信仰力评估体系 (Faith Power Assessment) ==========

enum AssessmentMode {
  PERSONAL
  FAMILY
  ENTERPRISE
}

enum FaithDimension {
  AWARENESS    // 觉察力
  RESILIENCE   // 定力
  VISION       // 格局力
  CONNECTION   // 连接力
  LEGACY       // 传承力
}

model FaithQuestion {
  id             String          @id @default(cuid())
  dimension      FaithDimension
  mode           AssessmentMode
  sortOrder      Int             @default(0)
  questionText   String          @db.Text
  options        Json            // [{key:"A"|"B"|"C"|"D", text:string, score:number, crossScores?:{}}]
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([mode, dimension, isActive])
  @@index([sortOrder])
}

model FaithAssessment {
  id          String          @id @default(cuid())
  userId      String?
  sessionId   String?
  mode        AssessmentMode
  answers     Json            // [{questionId, selectedOption, score}]

  awareness   Int             @default(0)
  resilience  Int             @default(0)
  vision      Int             @default(0)
  connection  Int             @default(0)
  legacy      Int             @default(0)
  totalScore  Int             @default(0)

  level       String
  levelCode   String

  strongestDimension  String?
  weakestDimension    String?
  recommendedThemes   String[]

  pointsEarned  Int           @default(0)
  completedAt   DateTime      @default(now())
  createdAt     DateTime      @default(now())

  @@index([userId, completedAt])
  @@index([sessionId])
  @@index([mode])
}

// ========== M37 圆满之路修行系统 ==========

enum CultivationRole {
  NONE
  SEEKER
  PRACTITIONER
  MENTOR
  MASTER
}

enum Realm {
  AWAKENING
  CLARIFYING
  SEEING
  ATTAINING
  INTEGRATING
  RETURNING
  GIVING_BACK
}

model CultivationApplication {
  id           String    @id @default(cuid())
