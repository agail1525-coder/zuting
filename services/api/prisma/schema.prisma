  action     String           // GRANT|REVOKE|UPGRADE|DOWNGRADE|EXPIRE
  fromRole   CultivationRole?
  toRole     CultivationRole?
  operatorId String?
  reason     String?          @db.Text
  createdAt  DateTime         @default(now())

  @@index([userId, createdAt])
}

model FulfillmentJourney {
  id               String    @id @default(cuid())
  userId           String    @unique
