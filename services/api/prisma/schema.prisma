  @@index([orderId])
}

// ========== 积分商城 ==========

model PointsProduct {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  coverImage    String?
  category      String   // COUPON / DISCOUNT / EXPERIENCE / PERK / BADGE
  pointsCost    Int
