  description  String
  createdAt    DateTime   @default(now())

  @@index([membershipId])
  @@index([source])
}

// ========== 二级分销 ==========

model InviteCode {
  id           String   @id @default(cuid())
  userId       String   @unique
  code         String   @unique // 6位字母数字
