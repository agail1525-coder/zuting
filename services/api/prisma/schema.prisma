enum PkbEntryKind {
  CHAT
  INSIGHT
  REFLECTION
  VOW_UPDATE
  SCRIPTURE_NOTE
}

enum PkbCategory {
  PERSONAL
  FAMILY
  CAREER
  DAILY_STRUGGLE
  GENERAL
}

enum PkbRecommendationStatus {
  PENDING
  READ
  PRACTICING
  DONE
  DISMISSED
}

model UserPkb {
  id              String    @id @default(cuid())
  userId          String    @unique
  personalVow     String?   @db.Text
  familyVow       String?   @db.Text
  careerVow       String?   @db.Text
  vowUpdatedAt    DateTime?
  vowRevelation   Json?
  revelationAt    DateTime?
  currentOxStage  Int       @default(1)
  dominantRings   Int[]     @default([])
  topTraditions   String[]  @default([])
