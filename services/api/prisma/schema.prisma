  @@index([userId])
}

model CultivationInviteCode {
  id         String    @id @default(cuid())
  code       String    @unique @default(cuid())
  issuerId   String
  issuer     User      @relation("InviteIssuer", fields: [issuerId], references: [id], onDelete: Cascade)
  assigneeId String?
  note       String?
  usedAt     DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([issuerId])
  @@index([code])
