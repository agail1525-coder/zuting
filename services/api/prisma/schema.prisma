// ========== 促销引擎 ==========

model Promotion {
  id            String         @id @default(cuid())
  name          String
  description   String?        @db.Text
  type          PromotionType
  discountType  String         // FIXED / PERCENT
  discountValue Int            // 固定金额(分) 或 百分比(1-100)
  minAmount     Int?           // 最低消费(分)
  maxDiscount   Int?           // 最大折扣(分)
  startAt       DateTime
  endAt         DateTime
  entityType    String?        // TRIP / ROUTE / ALL
