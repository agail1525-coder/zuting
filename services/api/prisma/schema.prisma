generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== 用户体系 ==========

model User {
  id           String    @id @default(cuid())
  phone        String?   @unique
  email        String?   @unique
  wechatOpenId  String?   @unique
  wechatUnionId String?   @unique
  googleId      String?   @unique
  nickname     String
  avatar       String?
  role         UserRole  @default(PILGRIM)
  language     String    @default("zh-CN")
  passwordHash    String?
  refreshToken    String?
  emailVerified   Boolean   @default(false)
  phoneVerified   Boolean   @default(false)
  lastLoginAt     DateTime?

  // ── M40 管理后台 双因素认证 ──
  otpSecret       String?
  otpEnabled      Boolean   @default(false)
  otpVerifiedAt   DateTime?
  isAiAgent       Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  practices     Practice[]
  trips         Trip[]
  posts         Post[]
  orders        Order[]
  journals      JournalEntry[]
  sessions      Session[]
  guideProfile  GuideProfile?
  reviews         Review[]
  reviewReplies   ReviewReply[]
  reviewVotes     ReviewVote[]
  notifications   Notification[]
  uploads         Upload[]
  reportsMade     ContentReport[] @relation("ReportsMade")
  reportsReviewed ContentReport[] @relation("ReportsReviewed")
  conversations   Conversation[]
  routeBookings   RouteBooking[]
  collections     Collection[]
  guides          Guide[]
  ownedTeams      Team[]          @relation("TeamOwner")
  teamMemberships TeamMember[]

  // ── M37 修行系统 ──
  cultivationAccess     Boolean         @default(false)
  cultivationRole       CultivationRole @default(NONE)
  cultivationGrantedBy  String?
  cultivationGrantedAt  DateTime?
  cultivationExpiresAt  DateTime?
  cultivationApplications CultivationApplication[]
  cultivationInvitesIssued CultivationInviteCode[] @relation("InviteIssuer")
  fulfillmentJourney    FulfillmentJourney?
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model VerificationCode {
  id        String   @id @default(cuid())
  target    String
  code      String
  type      String   // REGISTER, LOGIN, RESET_PASSWORD
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([target, type])
}

enum UserRole {
  PILGRIM
  GUIDE
  AMBASSADOR
  ADMIN
}

// ========== 宗教数据 ==========

model Religion {
  id     String  @id @default(cuid())
  name   String  @unique
  nameEn String
  slug   String  @unique
  symbol String?
  color  String?

  // ── 深度内容 (文化百科) ──
  heroImage     String? // 宏大场景图 (Hero 背景)
  tagline       String? // 一句话标语 / 恢弘口号
  summary       String? @db.Text // 2-3 句总览
  foundedYear   String? // "约公元前6世纪" / "约公元610年"
  founder       String? // 创始人 (可选)
  followers     String? // "约18亿"
  origin        String? @db.Text // 起源故事
  development   String? @db.Text // 发展历程
  keyEvents     Json?   // [{year, title, description}] 历史大事记
  contributions String? @db.Text // 对人类文明的贡献
  controversies String? @db.Text // 争议与反思
  sacredTexts   Json?   // [{name, description}] 圣典/经文

  // ── 商业实践 (信仰与企业文化) ──
  businessPhilosophy  String?  @db.Text   // 核心商业哲学 (1-2句)
  businessValues      Json?               // [{key, label, description}] 核心价值标签
  businessInsight     String?  @db.Text   // 如何助力企业 (2-3句)
  businessCases       Json?              // 结构化商业案例 (企业/大师/方法论/研究/书单)

  holySites  HolySite[]
  temples    Temple[]
  patriarchs Patriarch[]
  teachings  Teaching[]
  routes     Route[]

  // M40 文化与生命
  lifePerspectives LifeQuestionPerspective[]
  lifeStageGuides  LifeStageGuide[]
}

model HolySite {
  id          String  @id @default(cuid())
  name        String
  nameEn      String
  country     String
  latitude    Float
  longitude   Float
  utcOffset   Float
  description String  @db.Text
  imageUrl    String?
  soundEffect String?

  // M40: 媒体画廊扩展
  gallery     Json?    // [{url, caption, sortOrder}]
  panoUrl     String?  // 360° 全景 URL
  audioGuides Json?    // {zh, en, ja, ko, th, hi, ar}
  lastEditedBy String?
  version      Int     @default(1)

  // 旅行信息扩展
  openingHours  String?   // "8:00-17:00"
  ticketPrice   String?   // "免费" / "80元"
  bestSeason    String?   // "春秋两季"
  visitDuration String?   // "建议2-3小时"
  transport     String?   // 交通指南
  tips          String[]  // 参观贴士

  // 周边信息
  nearbyFood       Json?  // [{name, type, rating, distance}]
  nearbyStay       Json?  // [{name, type, price, distance}]
  nearbyExperience Json?  // [{name, duration, price}]
  nearbySights     Json?  // [{name, distance, description}]

  // 来源 / 审核 (Phase 1: AI 知识补全的祖庭入库)
  source        HolySiteSource @default(ADMIN)
  status        HolySiteStatus @default(ACTIVE)
  submittedById String?  // Phase 2: 用户提交的祖庭

  religionId String
  religion   Religion    @relation(fields: [religionId], references: [id])
  tripSites  TripSite[]
  routeSites RouteSite[]
  destinationPackages DestinationPackage[]

  @@index([religionId])
  @@index([latitude, longitude])
  @@index([source, status])
}

enum HolySiteSource {
  ADMIN          // 后台手工录入
  AI_KNOWLEDGE   // AI 知识库补全
  USER_SUBMITTED // Phase 2: 用户提交
}

enum HolySiteStatus {
  ACTIVE
  PENDING_REVIEW
  REJECTED
}

model Temple {
  id           String  @id @default(cuid())
  name         String
  nameEn       String?
  country      String
  foundingDate String?
  description  String  @db.Text
  imageUrl     String?
  latitude     Float?
  longitude    Float?

  // M40 extensions
  gallery            Json?
  historicalAbbots   Json?
  lastEditedBy       String?
  version            Int     @default(1)

  religionId String
  religion   Religion @relation(fields: [religionId], references: [id])

  @@index([religionId])
  @@index([latitude, longitude])
}

model Patriarch {
  id           String  @id @default(cuid())
  name         String
  nameEn       String?
  dates        String?
  title        String?
  biography    String  @db.Text
  coreTeaching String  @db.Text
  imageUrl     String?

  // Zen lineage fields
  school        String?   // 禅宗流派: 曹洞宗/临济宗/云门宗/法眼宗/沩仰宗
  generation    Int?      // 传承世次
  teacherId     String?   // 师承 (self-reference)
  teacher       Patriarch?  @relation("PatriarchLineage", fields: [teacherId], references: [id])
  disciples     Patriarch[] @relation("PatriarchLineage")
  koans         Json?     // [{title, content, source}]
  achievements  String?   @db.Text
  templeNames   Json?     // [{name, nameEn, role, location}]
  classicQuotes Json?     // [string]
  works         Json?     // [{title, description}]

  // M40 extensions
  gallery       Json?
  lineage       Json?
  lastEditedBy  String?
  version       Int       @default(1)

  religionId String
  religion   Religion @relation(fields: [religionId], references: [id])

  @@index([religionId])
  @@index([teacherId])
  @@index([school])
}

model Teaching {
  id            String  @id @default(cuid())
  name          String
  originalText  String  @db.Text
  sourceText    String?
  translationCn String? @db.Text

  religionId String
  religion   Religion @relation(fields: [religionId], references: [id])

  @@index([religionId])
}

// ========== 曹溪三十印 ==========

model Seal {
  id       Int        @id
  name     String
  series   SealSeries
  poem     String     @db.Text
  essence  String     @db.Text
  practice String     @db.Text
  vow      String     @db.Text
  color    String?
}

enum SealSeries {
  CHUYIN
  ZHONGYIN
  YINGUOYIN
  CHENGDAOYIN
  GUIYUANYIN
}

// ========== 修行记录 ==========

model Practice {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  sealId   Int
  date     DateTime @default(now())
  duration Int?
  note     String?  @db.Text

  @@index([userId])
  @@index([date])
}

// ========== 旅行规划 ==========

model Trip {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  title        String
  startDate    DateTime?
  endDate      DateTime?
  status       TripStatus @default(DRAFT)
  totalBudget  Int?       // in cents (分)
  persons      Int        @default(1)
  contactName  String?
  contactPhone String?
  note         String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  guideId       String?
  guide         GuideProfile? @relation("TripGuide", fields: [guideId], references: [id])
  sites         TripSite[]
  statusHistory TripStatusHistory[]
  orders        Order[]
  journals      JournalEntry[]

  @@index([userId])
  @@index([status])
  @@index([guideId])
}

// Enhanced Trip Status - 12 state lifecycle
enum TripStatus {
  DRAFT           // 草稿
  PLANNING        // 规划中
  SUBMITTED       // 已提交
  CONFIRMED       // 已确认
  PAID            // 已支付
  PREPARING       // 准备中
  IN_PROGRESS     // 朝圣中
  COMPLETED       // 已完成
  REVIEWING       // 评价中
  CANCELLED       // 已取消
  REFUNDING       // 退款中
  REFUNDED        // 已退款
}

// Trip Status History - audit trail
model TripStatusHistory {
  id         String     @id @default(cuid())
  tripId     String
  trip       Trip       @relation(fields: [tripId], references: [id])
  fromStatus TripStatus
  toStatus   TripStatus
  event      String     // e.g. "user_submit", "admin_confirm", "payment_success"
  operator   String?    // who triggered: userId or "system"
  reason     String?    // optional reason for cancellation/refund
  createdAt  DateTime   @default(now())

  @@index([tripId])
}

// Order for trip payment
model Order {
  id            String      @id @default(cuid())
  orderNo       String      @unique  // OD + timestamp + random
  tripId        String?
  trip          Trip?       @relation(fields: [tripId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  totalAmount   Int         // in cents (分)
  paidAmount    Int?        // actual paid amount
  paymentMethod String?     // wechat/alipay/stripe
  paymentId     String?     // external payment ID
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  cancelledAt   DateTime?
  refundedAt    DateTime?
  discountAmount  Int?        // 优惠金额(分)
  couponId        String?     // 使用的优惠券ID
  promotionId     String?     // 使用的促销活动ID

  transactions    PaymentTransaction[]
  routeBookings   RouteBooking[]

  @@index([userId])
  @@index([tripId])
  @@index([orderNo])
}

enum OrderStatus {
  PENDING     // 待支付
  PAID        // 已支付
  CANCELLED   // 已取消
  REFUNDING   // 退款中
  REFUNDED    // 已退款
}

// Journal entry for pilgrimage diary
model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  siteId    String?
  title     String
  content   String   @db.Text
  images    String[]
  mood      String?  // 感悟/喜悦/平静/震撼
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tripId])
}

model TripSite {
  id        String    @id @default(cuid())
  tripId    String
  trip      Trip      @relation(fields: [tripId], references: [id])
  siteId    String
  site      HolySite  @relation(fields: [siteId], references: [id])
  order     Int
  visitDate DateTime?
  notes     String?   @db.Text

  @@index([tripId])
}

// ========== 社区 ==========

model Post {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String   @db.Text
  images    String[]
  siteTag   String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ========== P1: 支付交易 ==========

model PaymentTransaction {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  gateway         String   // wechat / alipay / stripe
  transactionId   String?  @unique // 外部交易号
  amount          Int      // in cents (分)
  currency        String   @default("CNY")
  status          String   @default("PENDING") // PENDING / SUCCESS / FAILED / REFUNDED
  callbackPayload Json?    // 回调原始数据
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([transactionId])
}

// ========== P1: 导游 ==========

model GuideProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  realName        String
  idNumber        String?
  certifications  String[] // 导游证号
  languages       String[] // 服务语言
  specialties     String[] // 擅长信仰体系
  bio             String?  @db.Text
  avatarUrl       String?
  rating          Float    @default(0)
  totalTrips      Int      @default(0)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trips Trip[] @relation("TripGuide")
}

// ========== P1: 评价 ==========

model Review {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  targetType   String   // TRIP / GUIDE / SITE
  targetId     String
  rating       Int      // 1-5
  content      String?  @db.Text
  images       String[]
  status       String   @default("PENDING") // PENDING / APPROVED / REJECTED / HIDDEN
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  replies      ReviewReply[]
  votes        ReviewVote[]

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status])
}

// ========== 评价回复 ==========

model ReviewReply {
  id         String   @id @default(cuid())
  reviewId   String
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  isOfficial Boolean  @default(false)
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([reviewId])
}

// ========== 评价投票 ==========

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

// ========== 浏览历史 ==========

model UserViewHistory {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  entityType String
  entityId   String
  viewedAt   DateTime @default(now())

  @@index([userId, viewedAt])
  @@index([entityType, entityId])
}

// ========== P2: 通知 ==========

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // TRIP_STATUS / PAYMENT / SYSTEM / REVIEW / PROMOTION
  title     String
  content   String   @db.Text
  link      String?  // 跳转路径 e.g. /trips/xxx
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// ========== P2: 文件上传 ==========

model Upload {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  filename   String
  mimetype   String
  size       Int      // bytes
  url        String   // CDN URL
  provider   String   @default("local") // local / oss / s3
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ========== P4: 合规 ==========

model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("ReportsMade", fields: [reporterId], references: [id])
  targetType  String   // JOURNAL / POST / REVIEW
  targetId    String
  reason      String   // INAPPROPRIATE / OFFENSIVE / SPAM / RELIGIOUS_SENSITIVE
  description String?  @db.Text
  status      String   @default("PENDING") // PENDING / REVIEWED / DISMISSED
  reviewedBy  String?
  reviewer    User?    @relation("ReportsReviewed", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([targetType, targetId])
}

// ========== 路线产品 ==========

model Route {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String          // 六祖慧能路线
  titleEn     String          // Sixth Patriarch Huineng Route
  subtitle    String          // "追随六祖足迹，体验禅宗精髓"
  category    RouteCategory
  difficulty  RouteDifficulty
  duration    Int             // 天数
  nights      Int             // 住宿晚数
  coverImage  String?         // 封面图
  images      String[]        // 图片集
  highlights  String[]        // 亮点标签
  description String          @db.Text  // 详细介绍
  itinerary   Json            // 逐日行程JSON
  priceFrom   Int             // 起价(分)
  included    String[]        // 包含项
  excluded    String[]        // 不含项
  tips        String[]        // 贴士
  season      String          // 最佳季节
  groupSize   String          // 建议人数
  status      RouteStatus     @default(DRAFT)
  rating      Float?
  reviewCount Int             @default(0)
  bookCount   Int             @default(0)

  // M40 extensions
  coverGallery Json?
  dailyPlan    Json?
  lastEditedBy String?
  version      Int       @default(1)

  religionId  String?
  religion    Religion?       @relation(fields: [religionId], references: [id])
  sites       RouteSite[]
  bookings    RouteBooking[]
  destinationPackages DestinationPackage[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([status])
  @@index([religionId])
}

model RouteSite {
  id       String   @id @default(cuid())
  routeId  String
  route    Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  siteId   String
  site     HolySite @relation(fields: [siteId], references: [id])
  day      Int      // 第几天到达
  order    Int      // 当天顺序
  duration String?  // 建议停留时间
  note     String?  // 该站点特别说明

  @@index([routeId])
  @@index([siteId])
}

model RouteBooking {
  id           String        @id @default(cuid())
  routeId      String
  route        Route         @relation(fields: [routeId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  startDate    DateTime
  persons      Int           @default(1)
  contactName  String?
  contactPhone String?
  note         String?
  totalPrice   Int           // 分
  status       BookingStatus @default(PENDING)
  orderId      String?       // 关联订单
  order        Order?        @relation(fields: [orderId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([routeId])
  @@index([userId])
  @@index([status])
}

enum RouteCategory {
  ZEN
  BUDDHIST
  TAOIST
  CHRISTIAN
  ISLAMIC
  HINDU
  JEWISH
  CROSS_CULTURAL
  CULTURAL_HERITAGE
}

enum RouteDifficulty {
  EASY
  MODERATE
  CHALLENGING
}

enum RouteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

// ========== 攻略社区 ==========

model Guide {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  title        String
  coverImage   String?
  content      String      @db.Text
  entityType   String?     // HOLY_SITE / TEMPLE
  entityId     String?
  tags         String[]
  status       GuideStatus @default(DRAFT)
  viewCount    Int         @default(0)
  likeCount    Int         @default(0)
  commentCount Int         @default(0)
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  comments GuideComment[]
  likes    GuideLike[]

  @@index([userId])
  @@index([status, createdAt])
  @@index([entityType, entityId])
}

model GuideComment {
  id        String   @id @default(cuid())
  guideId   String
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([guideId])
}

model GuideLike {
  id        String   @id @default(cuid())
  guideId   String
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([guideId, userId])
  @@index([guideId])
}

enum GuideStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

model Question {
  id          String         @id @default(cuid())
  userId      String
  title       String
  content     String         @db.Text
  entityType  String?
  entityId    String?
  tags        String[]
  status      QuestionStatus @default(OPEN)
  viewCount   Int            @default(0)
  answerCount Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  answers Answer[]

  @@index([userId])
  @@index([status, createdAt])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  content    String   @db.Text
  isAccepted Boolean  @default(false)
  voteCount  Int      @default(0)
  createdAt  DateTime @default(now())

