  createdAt   DateTime  @default(now())

  @@unique([promotionId, userId, orderId])
  @@index([userId])
}

enum PromotionType {
  TIME_LIMITED // 限时折扣
  EARLY_BIRD   // 早鸟价
  FLASH_SALE   // 闪购
}

// ========== 会员体系 ==========

model Membership {
