// ========== 套餐打包 ==========

model TravelPackage {
  id           String   @id @default(cuid())
  name         String
  description  String?  @db.Text
  coverImage   String?
  packageType  String   // CLASSIC / DEEP / VIP / FREE / GROUP
  basePrice    Int      // 基础价(分)
  memberPrice  Int?     // 会员价(分)
