  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  entries         PkbEntry[]
  recommendations PkbRecommendation[]

  @@index([userId])
}

model PkbEntry {
  id                 String        @id @default(cuid())
  pkbId              String
  pkb                UserPkb       @relation(fields: [pkbId], references: [id], onDelete: Cascade)
  kind               PkbEntryKind
  category           PkbCategory   @default(GENERAL)
  title              String
  content            String        @db.Text
  xiaohongSessionId  String?
  userMessage        String?       @db.Text
  xiaohongReply      String?       @db.Text
  citedScriptureIds  String[]      @default([])
  citedChapterRefs   Json?         // [{slug, chapterNo, quote}]
  tags               String[]      @default([])
  mood               String?
  isShared           Boolean       @default(false)
  sharedGuideId      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([pkbId, createdAt])
  @@index([pkbId, category])
  @@index([pkbId, kind])
}

model PkbRecommendation {
  id          String                  @id @default(cuid())
  pkbId       String
  pkb         UserPkb                 @relation(fields: [pkbId], references: [id], onDelete: Cascade)
  category    PkbCategory
  title       String
  reason      String                  @db.Text
  scriptureId String?
  scriptureSlug String?
  chapterNo   Int?
  revelationNote  String?                @db.Text
  chapterPlan     Json?
  priority    Int                     @default(5)
  status      PkbRecommendationStatus @default(PENDING)
  expiresAt   DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([pkbId, status])
  @@index([pkbId, createdAt])
}

