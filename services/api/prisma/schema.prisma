generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== 用户体系 ==========

model User {
  id           String    @id @default(cuid())
  phone        String?   @unique
  email        String?   @unique
  wechatOpenId  String?   @unique
  wechatUnionId String?   @unique
  googleId      String?   @unique
  nickname     String
  avatar       String?
  role         UserRole  @default(PILGRIM)
  language     String    @default("zh-CN")
  passwordHash    String?
  refreshToken    String?
  emailVerified   Boolean   @default(false)
  phoneVerified   Boolean   @default(false)
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  practices     Practice[]
  trips         Trip[]
  posts         Post[]
  orders        Order[]
  journals      JournalEntry[]
  sessions      Session[]
  guideProfile  GuideProfile?
  reviews         Review[]
  reviewReplies   ReviewReply[]
  reviewVotes     ReviewVote[]
  notifications   Notification[]
  uploads         Upload[]
  reportsMade     ContentReport[] @relation("ReportsMade")
  reportsReviewed ContentReport[] @relation("ReportsReviewed")
  conversations   Conversation[]
  routeBookings   RouteBooking[]
  collections     Collection[]
  guides          Guide[]
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model VerificationCode {
  id        String   @id @default(cuid())
  target    String
  code      String
  type      String   // REGISTER, LOGIN, RESET_PASSWORD
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([target, type])
}

enum UserRole {
  PILGRIM
  GUIDE
  AMBASSADOR
  ADMIN
}

// ========== 宗教数据 ==========

model Religion {
  id     String  @id @default(cuid())
  name   String  @unique
  nameEn String
  slug   String  @unique
  symbol String?
  color  String?

  holySites  HolySite[]
  temples    Temple[]
  patriarchs Patriarch[]
  teachings  Teaching[]
  routes     Route[]
}

model HolySite {
  id          String  @id @default(cuid())
  name        String
  nameEn      String
  country     String
  latitude    Float
  longitude   Float
  utcOffset   Float
  description String  @db.Text
  imageUrl    String?
  soundEffect String?

  // 旅行信息扩展
  openingHours  String?   // "8:00-17:00"
  ticketPrice   String?   // "免费" / "80元"
  bestSeason    String?   // "春秋两季"
  visitDuration String?   // "建议2-3小时"
  transport     String?   // 交通指南
  tips          String[]  // 参观贴士

  // 周边信息
  nearbyFood       Json?  // [{name, type, rating, distance}]
  nearbyStay       Json?  // [{name, type, price, distance}]
  nearbyExperience Json?  // [{name, duration, price}]
  nearbySights     Json?  // [{name, distance, description}]

  religionId String
  religion   Religion    @relation(fields: [religionId], references: [id])
  tripSites  TripSite[]
  routeSites RouteSite[]

  @@index([religionId])
}

model Temple {
  id           String  @id @default(cuid())
  name         String
  nameEn       String?
  country      String
  foundingDate String?
  description  String  @db.Text
  imageUrl     String?
  latitude     Float?
  longitude    Float?

  religionId String
  religion   Religion @relation(fields: [religionId], references: [id])

  @@index([religionId])
}

model Patriarch {
  id           String  @id @default(cuid())
  name         String
  nameEn       String?
  dates        String?
  title        String?
  biography    String  @db.Text
  coreTeaching String  @db.Text
  imageUrl     String?

  religionId String
  religion   Religion @relation(fields: [religionId], references: [id])

  @@index([religionId])
}

model Teaching {
  id            String  @id @default(cuid())
  name          String
  originalText  String  @db.Text
  sourceText    String?
  translationCn String? @db.Text

  religionId String
  religion   Religion @relation(fields: [religionId], references: [id])

  @@index([religionId])
}

// ========== 曹溪三十印 ==========

model Seal {
  id       Int        @id
  name     String
  series   SealSeries
  poem     String     @db.Text
  essence  String     @db.Text
  practice String     @db.Text
  vow      String     @db.Text
  color    String?
}

enum SealSeries {
  CHUYIN
  ZHONGYIN
  YINGUOYIN
  CHENGDAOYIN
  GUIYUANYIN
}

// ========== 修行记录 ==========

model Practice {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  sealId   Int
  date     DateTime @default(now())
  duration Int?
  note     String?  @db.Text

  @@index([userId])
  @@index([date])
}

// ========== 旅行规划 ==========

model Trip {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  title        String
  startDate    DateTime?
  endDate      DateTime?
  status       TripStatus @default(DRAFT)
  totalBudget  Int?       // in cents (分)
  persons      Int        @default(1)
  contactName  String?
  contactPhone String?
  note         String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  guideId       String?
  guide         GuideProfile? @relation("TripGuide", fields: [guideId], references: [id])
  sites         TripSite[]
  statusHistory TripStatusHistory[]
  orders        Order[]
  journals      JournalEntry[]

  @@index([userId])
  @@index([status])
  @@index([guideId])
}

// Enhanced Trip Status - 12 state lifecycle
enum TripStatus {
  DRAFT           // 草稿
  PLANNING        // 规划中
  SUBMITTED       // 已提交
  CONFIRMED       // 已确认
  PAID            // 已支付
  PREPARING       // 准备中
  IN_PROGRESS     // 朝圣中
  COMPLETED       // 已完成
  REVIEWING       // 评价中
  CANCELLED       // 已取消
  REFUNDING       // 退款中
  REFUNDED        // 已退款
}

// Trip Status History - audit trail
model TripStatusHistory {
  id         String     @id @default(cuid())
  tripId     String
  trip       Trip       @relation(fields: [tripId], references: [id])
  fromStatus TripStatus
  toStatus   TripStatus
  event      String     // e.g. "user_submit", "admin_confirm", "payment_success"
  operator   String?    // who triggered: userId or "system"
  reason     String?    // optional reason for cancellation/refund
  createdAt  DateTime   @default(now())

  @@index([tripId])
}

// Order for trip payment
model Order {
  id            String      @id @default(cuid())
  orderNo       String      @unique  // OD + timestamp + random
  tripId        String
  trip          Trip        @relation(fields: [tripId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  totalAmount   Int         // in cents (分)
  paidAmount    Int?        // actual paid amount
  paymentMethod String?     // wechat/alipay/stripe
  paymentId     String?     // external payment ID
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  cancelledAt   DateTime?
  refundedAt    DateTime?
  discountAmount  Int?        // 优惠金额(分)
  couponId        String?     // 使用的优惠券ID
  promotionId     String?     // 使用的促销活动ID

  transactions PaymentTransaction[]

  @@index([userId])
  @@index([tripId])
  @@index([orderNo])
}

enum OrderStatus {
  PENDING     // 待支付
  PAID        // 已支付
  CANCELLED   // 已取消
  REFUNDING   // 退款中
  REFUNDED    // 已退款
}

// Journal entry for pilgrimage diary
model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  siteId    String?
  title     String
  content   String   @db.Text
  images    String[]
  mood      String?  // 感悟/喜悦/平静/震撼
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tripId])
}

model TripSite {
  id        String    @id @default(cuid())
  tripId    String
  trip      Trip      @relation(fields: [tripId], references: [id])
  siteId    String
  site      HolySite  @relation(fields: [siteId], references: [id])
  order     Int
  visitDate DateTime?
  notes     String?   @db.Text

  @@index([tripId])
}

// ========== 社区 ==========

model Post {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String   @db.Text
  images    String[]
  siteTag   String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ========== P1: 支付交易 ==========

model PaymentTransaction {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  gateway         String   // wechat / alipay / stripe
  transactionId   String?  @unique // 外部交易号
  amount          Int      // in cents (分)
  currency        String   @default("CNY")
  status          String   @default("PENDING") // PENDING / SUCCESS / FAILED / REFUNDED
  callbackPayload Json?    // 回调原始数据
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([transactionId])
}

// ========== P1: 导游 ==========

model GuideProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  realName        String
  idNumber        String?
  certifications  String[] // 导游证号
  languages       String[] // 服务语言
  specialties     String[] // 擅长信仰体系
  bio             String?  @db.Text
  avatarUrl       String?
  rating          Float    @default(0)
  totalTrips      Int      @default(0)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trips Trip[] @relation("TripGuide")
}

// ========== P1: 评价 ==========

model Review {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  targetType   String   // TRIP / GUIDE / SITE
  targetId     String
  rating       Int      // 1-5
  content      String?  @db.Text
  images       String[]
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  replies      ReviewReply[]
  votes        ReviewVote[]

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

// ========== 评价回复 ==========

model ReviewReply {
  id         String   @id @default(cuid())
  reviewId   String
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  isOfficial Boolean  @default(false)
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([reviewId])
}

// ========== 评价投票 ==========

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

// ========== 浏览历史 ==========

model UserViewHistory {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  entityType String
  entityId   String
  viewedAt   DateTime @default(now())

  @@index([userId, viewedAt])
  @@index([entityType, entityId])
}

// ========== P2: 通知 ==========

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // TRIP_STATUS / PAYMENT / SYSTEM / REVIEW / PROMOTION
  title     String
  content   String   @db.Text
  link      String?  // 跳转路径 e.g. /trips/xxx
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// ========== P2: 文件上传 ==========

model Upload {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  filename   String
  mimetype   String
  size       Int      // bytes
  url        String   // CDN URL
  provider   String   @default("local") // local / oss / s3
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ========== P4: 合规 ==========

model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("ReportsMade", fields: [reporterId], references: [id])
  targetType  String   // JOURNAL / POST / REVIEW
  targetId    String
  reason      String   // INAPPROPRIATE / OFFENSIVE / SPAM / RELIGIOUS_SENSITIVE
  description String?  @db.Text
  status      String   @default("PENDING") // PENDING / REVIEWED / DISMISSED
  reviewedBy  String?
  reviewer    User?    @relation("ReportsReviewed", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([targetType, targetId])
}

// ========== 路线产品 ==========

model Route {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String          // 六祖慧能路线
  titleEn     String          // Sixth Patriarch Huineng Route
  subtitle    String          // "追随六祖足迹，体验禅宗精髓"
  category    RouteCategory
  difficulty  RouteDifficulty
  duration    Int             // 天数
  nights      Int             // 住宿晚数
  coverImage  String?         // 封面图
  images      String[]        // 图片集
  highlights  String[]        // 亮点标签
  description String          @db.Text  // 详细介绍
  itinerary   Json            // 逐日行程JSON
  priceFrom   Int             // 起价(分)
  included    String[]        // 包含项
  excluded    String[]        // 不含项
  tips        String[]        // 贴士
  season      String          // 最佳季节
  groupSize   String          // 建议人数
  status      RouteStatus     @default(DRAFT)
  rating      Float?
  reviewCount Int             @default(0)
  bookCount   Int             @default(0)

  religionId  String?
  religion    Religion?       @relation(fields: [religionId], references: [id])
  sites       RouteSite[]
  bookings    RouteBooking[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([status])
  @@index([religionId])
}

model RouteSite {
  id       String   @id @default(cuid())
  routeId  String
  route    Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  siteId   String
  site     HolySite @relation(fields: [siteId], references: [id])
  day      Int      // 第几天到达
  order    Int      // 当天顺序
  duration String?  // 建议停留时间
  note     String?  // 该站点特别说明

  @@index([routeId])
  @@index([siteId])
}

model RouteBooking {
  id           String        @id @default(cuid())
  routeId      String
  route        Route         @relation(fields: [routeId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  startDate    DateTime
  persons      Int           @default(1)
  contactName  String?
  contactPhone String?
  note         String?
  totalPrice   Int           // 分
  status       BookingStatus @default(PENDING)
  orderId      String?       // 关联订单

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([routeId])
  @@index([userId])
  @@index([status])
}

enum RouteCategory {
  ZEN
  BUDDHIST
  TAOIST
  CHRISTIAN
  ISLAMIC
  HINDU
  JEWISH
  CROSS_CULTURAL
  CULTURAL_HERITAGE
}

enum RouteDifficulty {
  EASY
  MODERATE
  CHALLENGING
}

enum RouteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

// ========== 攻略社区 ==========

model Guide {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  title        String
  coverImage   String?
  content      String      @db.Text
  entityType   String?     // HOLY_SITE / TEMPLE
  entityId     String?
  tags         String[]
  status       GuideStatus @default(DRAFT)
  viewCount    Int         @default(0)
  likeCount    Int         @default(0)
  commentCount Int         @default(0)
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  comments GuideComment[]
  likes    GuideLike[]

  @@index([userId])
  @@index([status, createdAt])
  @@index([entityType, entityId])
}

model GuideComment {
  id        String   @id @default(cuid())
  guideId   String
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([guideId])
}

model GuideLike {
  id        String   @id @default(cuid())
  guideId   String
  guide     Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([guideId, userId])
  @@index([guideId])
}

enum GuideStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

model Question {
  id          String         @id @default(cuid())
  userId      String
  title       String
  content     String         @db.Text
  entityType  String?
  entityId    String?
  tags        String[]
  status      QuestionStatus @default(OPEN)
  viewCount   Int            @default(0)
  answerCount Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  answers Answer[]

  @@index([userId])
  @@index([status, createdAt])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  content    String   @db.Text
  isAccepted Boolean  @default(false)
  voteCount  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([questionId])
}

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String?
  avatar         String?
  bio            String?  @db.Text
  location       String?
  pilgrimLevel   Int      @default(1)
  totalTrips     Int      @default(0)
  totalSites     Int      @default(0)
  guideCount     Int      @default(0)
  reviewCount    Int      @default(0)
  followerCount  Int      @default(0)
  followingCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ========== AI 配置 + 对话历史 ==========

model AiConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  label       String
  description String?
  category    String   @default("general") // general / model / prompt / safety
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Conversation {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id])
  title     String?
  messages  ConversationMessage[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user / assistant / system
  content        String       @db.Text
  intent         String?
  tokenCount     Int?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// ========== P4: 优惠券 ==========

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  type        String    // FIXED / PERCENT
  value       Int       // 固定金额(分) 或 百分比(1-100)
  minAmount   Int?      // 最低消费(分)
  maxDiscount Int?      // 最大折扣(分)，百分比券用
  totalCount  Int       @default(0) // 0=无限
  usedCount   Int       @default(0)
  startAt     DateTime
  endAt       DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  usages      CouponUsage[]
  userCoupons UserCoupon[]
}

model UserCoupon {
  id        String           @id @default(cuid())
  couponId  String
  coupon    Coupon           @relation(fields: [couponId], references: [id])
  userId    String
  status    UserCouponStatus @default(AVAILABLE)
  orderId   String?          // 使用时关联的订单
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@unique([couponId, userId])
  @@index([userId, status])
}

enum UserCouponStatus {
  AVAILABLE // 已领取未使用
  USED      // 已使用
  EXPIRED   // 已过期
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    String
  orderId   String?
  discount  Int      // 实际抵扣金额(分)
  createdAt DateTime @default(now())

  @@unique([couponId, userId, orderId])
  @@index([userId])
}

// ========== 搜索统计 ==========

model SearchStat {
  id        String   @id @default(cuid())
  keyword   String   @unique
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([count])
}

// ========== 收藏系统 ==========

enum CollectionEntityType {
  HOLY_SITE
  TEMPLE
  PATRIARCH
  TRIP
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String   @default("默认收藏夹")
  description String?
  coverImage  String?
  isPublic    Boolean  @default(false)
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String               @id @default(cuid())
  collectionId String
  collection   Collection           @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  entityType   CollectionEntityType
  entityId     String
  note         String?
  createdAt    DateTime             @default(now())

  @@unique([collectionId, entityType, entityId])
  @@index([collectionId])
  @@index([entityType, entityId])
}

// ========== 促销引擎 ==========

model Promotion {
  id            String         @id @default(cuid())
  name          String
  description   String?        @db.Text
  type          PromotionType
  discountType  String         // FIXED / PERCENT
  discountValue Int            // 固定金额(分) 或 百分比(1-100)
  minAmount     Int?           // 最低消费(分)
  maxDiscount   Int?           // 最大折扣(分)
  startAt       DateTime
  endAt         DateTime
  entityType    String?        // TRIP / ROUTE / ALL
  entityIds     String[]       // 适用的行程/路线ID列表, 空=全部
  totalQuota    Int            @default(0) // 0=无限
  usedQuota     Int            @default(0)
  coverImage    String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  usages PromotionUsage[]

  @@index([type, isActive])
  @@index([startAt, endAt])
}

model PromotionUsage {
  id          String    @id @default(cuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id])
  userId      String
  orderId     String?
  discount    Int       // 实际抵扣金额(分)
  createdAt   DateTime  @default(now())

  @@unique([promotionId, userId, orderId])
  @@index([userId])
}

enum PromotionType {
  TIME_LIMITED // 限时折扣
  EARLY_BIRD   // 早鸟价
  FLASH_SALE   // 闪购
}

// ========== 会员体系 ==========

model Membership {
  id              String   @id @default(cuid())
  userId          String   @unique
  level           Int      @default(1) // 1-5
  levelName       String   @default("朝圣新手")
  totalPoints     Int      @default(0)
  availablePoints Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  points PointsTransaction[]

  @@index([level])
}

model PointsTransaction {
  id           String     @id @default(cuid())
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  type         String     // EARN / SPEND
  amount       Int        // positive for earn, positive for spend
  source       String     // ORDER / GUIDE / REVIEW / CHECKIN / INVITE / REFERRAL_REWARD / REDEEM
  sourceId     String?
  description  String
  createdAt    DateTime   @default(now())

  @@index([membershipId])
  @@index([source])
}

// ========== 二级分销 ==========

model InviteCode {
  id           String   @id @default(cuid())
  userId       String   @unique
  code         String   @unique // 6位字母数字
  totalInvites Int      @default(0)
  totalRewards Int      @default(0) // 累计返佣积分
  createdAt    DateTime @default(now())
}

model Referral {
  id        String   @id @default(cuid())
  inviterId String
  inviteeId String   @unique
  level     Int      // 1=一级 2=二级
  createdAt DateTime @default(now())

  rewards ReferralReward[]

  @@index([inviterId])
}

model ReferralReward {
  id         String   @id @default(cuid())
  referralId String
  referral   Referral @relation(fields: [referralId], references: [id])
  orderId    String
  inviterId  String
  amount     Int      // 返佣积分数
  level      Int      // 1或2
  status     String   @default("PENDING") // PENDING / SETTLED / CANCELLED
  settledAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([inviterId])
  @@index([orderId])
}

// ========== 积分商城 ==========

model PointsProduct {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  coverImage    String?
  category      String   // COUPON / DISCOUNT / EXPERIENCE / PERK / BADGE
  pointsCost    Int
  originalPrice Int?     // 原价(分)
  stock         Int      @default(0) // 0=无限
  soldCount     Int      @default(0)
  metadata      Json?    // couponId/discountPercent/badgeImage等
  isActive      Boolean  @default(true)
  startAt       DateTime?
  endAt         DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  exchanges PointsExchange[]

  @@index([category, isActive])
}

model PointsExchange {
  id          String        @id @default(cuid())
  userId      String
  productId   String
  product     PointsProduct @relation(fields: [productId], references: [id])
  pointsSpent Int
  status      String        @default("PENDING") // PENDING / FULFILLED / CANCELLED
  metadata    Json?         // 兑换结果详情
  createdAt   DateTime      @default(now())

  @@index([userId])
  @@index([productId])
}

// ========== 价格工具 ==========

model PriceSnapshot {
  id         String   @id @default(cuid())
  entityType String   // PACKAGE / ROUTE
  entityId   String
  date       DateTime @db.Date
  price      Int      // cents
  currency   String   @default("CNY")
  createdAt  DateTime @default(now())

  @@unique([entityType, entityId, date])
  @@index([entityType, entityId])
}

model PriceAlert {
  id           String    @id @default(cuid())
  userId       String
  entityType   String
  entityId     String
  entityName   String
  targetPrice  Int       // cents
  currentPrice Int       // cents
  isTriggered  Boolean   @default(false)
  triggeredAt  DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([userId, isActive])
  @@index([entityType, entityId])
}

// ========== 套餐打包 ==========

model TravelPackage {
  id           String   @id @default(cuid())
  name         String
  description  String?  @db.Text
  coverImage   String?
  packageType  String   // CLASSIC / DEEP / VIP / FREE / GROUP
  basePrice    Int      // 基础价(分)
  memberPrice  Int?     // 会员价(分)
  includes     Json     // {accommodation, transport, guide, meals}
  duration     Int      // 天数
  maxPersons   Int      @default(20)
  entityType   String?  // HOLY_SITE / TEMPLE
  entityIds    String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings PackageBooking[]

  @@index([packageType, isActive])
}

model PackageBooking {
  id           String        @id @default(cuid())
  packageId    String
  package      TravelPackage @relation(fields: [packageId], references: [id])
  userId       String
  orderId      String?
  persons      Int
  totalPrice   Int           // 实付(分)
  status       String        @default("PENDING") // PENDING / CONFIRMED / CANCELLED
  startDate    DateTime
  contactName  String?
  contactPhone String?
  createdAt    DateTime      @default(now())

  @@index([userId])
  @@index([packageId])
}

// ========== 社交分享 ==========

model Share {
  id         String   @id @default(cuid())
  userId     String?
  platform   String   // WECHAT / WEIBO / FACEBOOK / TWITTER / WHATSAPP / COPY / NATIVE
  entityType String   // HOLY_SITE / TEMPLE / TRIP / GUIDE / QUESTION / PROMOTION / PACKAGE
  entityId   String
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([platform])
}

// ========== 商家入驻 ==========

model Merchant {
  id            String         @id @default(cuid())
  userId        String         @unique
  type          String         // TEMPLE / GUIDE / ACCOMMODATION / TRANSPORT
  name          String
  description   String?        @db.Text
  logo          String?
  license       String?        // 营业执照/资质证书URL
  status        MerchantStatus @default(PENDING)
  contactPhone  String?
  contactEmail  String?
  address       String?
  province      String?
  city          String?
  rating        Float          @default(0)
  totalOrders   Int            @default(0)
  totalRevenue  Int            @default(0) // cents
  rejectedReason String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  services MerchantService[]

  @@index([type, status])
  @@index([status])
}

model MerchantService {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  name        String
  description String?  @db.Text
  coverImage  String?
  price       Int      // cents
  duration    Int?     // minutes
  maxPersons  Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([merchantId, isActive])
}

enum MerchantStatus {
  PENDING   // 待审核
  APPROVED  // 审核通过
  ACTIVE    // 正常运营
  SUSPENDED // 已暂停
  REJECTED  // 已拒绝
  CLOSED    // 已关闭
}

// ========== 实时消息 ==========

model ChatRoom {
  id        String   @id @default(cuid())
  type      String   // PRIVATE / MERCHANT_INQUIRY / GUIDE_CHAT
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([type])
}

model ChatParticipant {
  id         String    @id @default(cuid())
  roomId     String
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  type      String   @default("TEXT") // TEXT / IMAGE / SYSTEM
  content   String   @db.Text
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([senderId])
}

// ========== 多媒体导览 ==========

model MediaContent {
  id           String   @id @default(cuid())
  entityType   String   // HOLY_SITE / TEMPLE
  entityId     String
  mediaType    String   // VIDEO / PANORAMA / AUDIO
  title        String
  description  String?  @db.Text
  url          String   // 媒体文件URL
  thumbnailUrl String?  // 缩略图
  duration     Int?     // 时长(秒)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId, isActive])
  @@index([mediaType])
}
