  source       CrawlerSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalUrl  String
  dedupKey     String   @unique
  title        String?
  description  String?  @db.Text
  raw          Json
  imageUrls    String[]
  status       String   @default("PENDING")
  targetType   String?
  targetId     String?
  errorLog     String?  @db.Text
  fetchedAt    DateTime @default(now())
  dispatchedAt DateTime?

  // CW-QG 质量守门 (防污染 v1.2)
  qualityScore     Float    @default(0)
  qualityLevel     String?  // APPROVED / PENDING_REVIEW / REJECTED
  sanitizedTitle   String?
  sanitizedContent String?  @db.Text
  rejectReasons    String[]

  @@index([sourceId, status])
  @@index([targetType, targetId])
  @@index([status, fetchedAt])
  @@index([qualityLevel, fetchedAt])
}

model CrawlerCoverageSnapshot {
  id           String   @id @default(cuid())
  takenAt      DateTime @default(now())
  domain       String
  channel      String
  sourceCount  Int      @default(0)
  activeCount  Int      @default(0)
  itemsLast24h Int      @default(0)
  avgHealth    Float    @default(0)
  status       String   @default("UNKNOWN")

  @@index([takenAt])
  @@index([domain, channel, takenAt])
}

model CrawlerRun {
  id            String        @id @default(cuid())
  sourceId      String
  source        CrawlerSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  startedAt     DateTime      @default(now())
  finishedAt    DateTime?
  status        String
  itemsFound    Int           @default(0)
  itemsCreated  Int           @default(0)
  itemsUpdated  Int           @default(0)
  itemsSkipped  Int           @default(0)
  alertsCount   Int           @default(0)
  errorLog      String?       @db.Text
  triggeredBy   String        @default("CRON")

  @@index([sourceId, startedAt])
}

model PackagePriceAlert {
  id           String        @id @default(cuid())
  packageId    String
  package      DestinationPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  oldPriceMin  Int
  newPriceMin  Int
  changeRatio  Float
  detectedAt   DateTime      @default(now())
  acknowledged Boolean       @default(false)
  note         String?

  @@index([acknowledged, detectedAt])
}
