  updatedAt      DateTime @updatedAt
}

// ========== AI 配置 + 对话历史 ==========

model AiConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  label       String
  description String?
  category    String   @default("general") // general / model / prompt / safety
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Conversation {
