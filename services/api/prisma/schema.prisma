  userId    String
  user      User                  @relation(fields: [userId], references: [id])
  title     String?
  messages  ConversationMessage[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user / assistant / system
  content        String       @db.Text
  intent         String?
  tokenCount     Int?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// ========== P4: 优惠券 ==========

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  type        String    // FIXED / PERCENT
  value       Int       // 固定金额(分) 或 百分比(1-100)
  minAmount   Int?      // 最低消费(分)
  maxDiscount Int?      // 最大折扣(分)，百分比券用
  totalCount  Int       @default(0) // 0=无限
  usedCount   Int       @default(0)
  startAt     DateTime
  endAt       DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  usages      CouponUsage[]
  userCoupons UserCoupon[]
}

model UserCoupon {
  id        String           @id @default(cuid())
  couponId  String
  coupon    Coupon           @relation(fields: [couponId], references: [id])
  userId    String
  status    UserCouponStatus @default(AVAILABLE)
  orderId   String?          // 使用时关联的订单
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@unique([couponId, userId])
  @@index([userId, status])
}

enum UserCouponStatus {
  AVAILABLE // 已领取未使用
  USED      // 已使用
  EXPIRED   // 已过期
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    String
  orderId   String?
  discount  Int      // 实际抵扣金额(分)
  createdAt DateTime @default(now())

  @@unique([couponId, userId, orderId])
  @@index([userId])
}

// ========== 搜索统计 ==========

model SearchStat {
  id        String   @id @default(cuid())
  keyword   String   @unique
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([count])
}

// ========== 收藏系统 ==========

enum CollectionEntityType {
  HOLY_SITE
  TEMPLE
  PATRIARCH
  TRIP
}

model Collection {
  id          String   @id @default(cuid())
