# ==============================================
# Zuting Global — Root Environment Variables
# ==============================================
# Copy this file to .env and fill in actual values.
# These vars are used by docker-compose and shared across services.

# ---- Database ----
DATABASE_URL="postgresql://zuting:zuting123@localhost:5435/zuting?schema=public"
POSTGRES_USER="zuting"
POSTGRES_PASSWORD="zuting123"
POSTGRES_DB="zuting"

# ---- Redis ----
REDIS_URL="redis://localhost:6380"
REDIS_PASSWORD=""

# ---- JWT ----
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- Server Ports ----
API_PORT=3002
WEB_PORT=3000

# ---- CORS ----
CORS_ORIGINS="http://localhost:3000,http://localhost:3003"

# ---- WeChat OAuth (open.weixin.qq.com) — Web Social Login ----
# Required for WeChat social login on web. Leave empty to disable.
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_REDIRECT_URI="http://localhost:3002/api/auth/wechat/callback"

# ---- WeChat Mini Program (mp.weixin.qq.com) ----
# Required for WeChat Mini Program wx.login(). Get from https://mp.weixin.qq.com
# The appid must also match project.config.json in apps/miniprogram/
WECHAT_MP_APP_ID=""
WECHAT_MP_APP_SECRET=""

# ---- Google OAuth ----
# Required for Google social login. Leave empty to disable.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3002/api/auth/google/callback"

# ---- AI ----
OPENAI_API_KEY=""

# ---- Web (build-time) ----
NEXT_PUBLIC_API_URL="http://localhost:3002"

# ---- Sentry Error Monitoring ----
SENTRY_DSN_API=""
NEXT_PUBLIC_SENTRY_DSN=""
VITE_SENTRY_DSN=""
# Mobile DSN is set in apps/mobile/app.json extra.SENTRY_DSN_MOBILE

# ---- Payment: WeChat Pay V3 ----
# Required for WeChat Pay production mode. Leave empty for mock mode.
WECHAT_PAY_APP_ID=""
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_SERIAL_NO=""
WECHAT_PAY_PRIVATE_KEY=""
WECHAT_PAY_API_V3_KEY=""
WECHAT_PAY_NOTIFY_URL=""

# ---- Payment: Alipay ----
# Required for Alipay production mode. Leave empty for mock mode.
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
ALIPAY_NOTIFY_URL=""

# ---- Payment: Stripe ----
# Required for Stripe production mode. Leave empty for mock mode.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ---- Production Docker Compose ----
# HTTP_PORT=80
# HTTPS_PORT=443
