{
  "expo": {
    "name": "Joinus",
    "slug": "zuting-travel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "joinus",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3264ff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zuting.travel"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3264ff"
      },
      "package": "com.zuting.travel"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3264ff"
        }
      ]
    ],
    "extra": {
      "SENTRY_DSN_MOBILE": "",
      "privacyUrl": "https://zuting.fszyl.top/privacy"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
