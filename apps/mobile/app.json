{
  "expo": {
    "name": "祖庭之旅",
    "slug": "zuting-travel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zuting",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zuting.travel"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.zuting.travel"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D4A855"
        }
      ]
    ],
    "extra": {
      "SENTRY_DSN_MOBILE": "",
      "privacyUrl": "https://zuting.fszyl.top/privacy"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
